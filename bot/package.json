{
  "name": "final-ancestor-bot",
  "version": "1.0.0",
  "description": "Discord bot for Final Ancestor Isle Evrima server",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsup",
    "start": "node dist/index.js",
    "dev": "bun src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src",
    "format": "biome format --write src",
    "check": "biome check --write src",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.58",
    "chalk": "^5.6.2",
    "chokidar": "^4.0.3",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.4",
    "postgres": "^3.4.5",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^22.10.5",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.29.1",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.7.3"
  }
}
