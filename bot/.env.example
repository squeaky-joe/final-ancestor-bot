DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_application_id
DISCORD_GUILD_ID=your_guild_id

DATABASE_URL=postgresql://user:password@localhost:5432/final_ancestor

# Path to the game server's Mods directory (can be a network share or local path).
# NOTE: this must be Binaries/Win64/Mods — NOT Binaries/Win64/ue4ss/Mods.
# Mod scripts live under ue4ss/Mods, but their Saved/ runtime data (the IPC files
# this bot reads and writes) resolves relative to the game process working directory,
# which is Binaries/Win64 itself.
MODS_PATH=C:/GameServer/TheIsle/Binaries/Win64/Mods

# Discord role/channel IDs
ADMIN_ROLE_ID=your_admin_role_id
STORAGE_CHANNEL_ID=optional_channel_restriction
